# Secrets file for load test scripts (PERF_INCIDENT_2026-06 Step 2.2).
#
# Usage: copy this file to loadtest/.env and fill in the values.
#   copy loadtest\env.example loadtest\.env
# loadtest/.env is git-ignored via the `.env*` pattern.
#
# WARNING: never put these values in the project root .env.local or set
# them with setx. If the local dev server / Playwright picks up
# LOADTEST_TOKEN, the test-route guard switches to token mode and every
# local E2E call to /api/test/* returns 404. Only scripts under
# loadtest/ may read this file.
#
# NOTE: keep comments in this file ASCII-only. Some readers (cmd for /f,
# PS 5.1 default encoding) corrupt UTF-8 Chinese bytes and can swallow
# line breaks, silently merging the next KEY=VALUE line into a comment.

# Staging (Vercel preview) URL, no trailing slash
STAGING_URL=https://larp-nexus-git-feat-perf-instrumentation-xxxx.vercel.app

# Token for /api/test/* routes (same value as the Vercel Preview env var LOADTEST_TOKEN)
LOADTEST_TOKEN=

# Vercel Deployment Protection "Protection Bypass for Automation" secret
VERCEL_BYPASS=
