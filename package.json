{
  "name": "larp-nexus",
  "version": "0.2.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:connection": "tsx scripts/test-connection.ts",
    "test:sendmail": "tsx scripts/test-sendmail.ts",
    "migrate:phase10": "tsx scripts/migrate-phase10.ts",
    "migrate:phase-e": "tsx scripts/migrate-phase-e.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cross-env E2E=1 CRON_SECRET=e2e-cron-secret playwright test",
    "test:e2e:smoke": "cross-env E2E=1 CRON_SECRET=e2e-cron-secret playwright test e2e/smoke",
    "test:e2e:flows": "cross-env E2E=1 CRON_SECRET=e2e-cron-secret playwright test e2e/flows",
    "test:e2e:ui": "cross-env E2E=1 CRON_SECRET=e2e-cron-secret playwright test --ui",
    "test:e2e:headed": "cross-env E2E=1 CRON_SECRET=e2e-cron-secret playwright test --headed",
    "test:e2e:debug": "cross-env E2E=1 CRON_SECRET=e2e-cron-secret PWDEBUG=1 playwright test --headed"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
