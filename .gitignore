# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# E2E temp file (MongoMemoryServer URI)
.e2e-mongo-uri

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright (e2e)
/playwright-report
/test-results
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local configuration (personal settings, not shared)
.claude/*.local.*
.claude/settings.local.json
.claude/CLAUDE.local.md

# Cursor debug logs
.cursor/debug.log
