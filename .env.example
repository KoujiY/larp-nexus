# ===== 必要環境變數 =====

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Next.js App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session Cookie 加密金鑰（至少 32 字元，使用 `openssl rand -base64 32` 生成）
SESSION_SECRET=

# Pusher WebSocket（後端）
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap3

# Pusher WebSocket（前端）
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap3

# Vercel Blob（檔案上傳）
BLOB_READ_WRITE_TOKEN=

# Email (Nodemailer + Gmail SMTP)
SMTP_USER=your@gmail.com
SMTP_PASS=
EMAIL_FROM=your@gmail.com

# ===== AI 角色匯入 =====
# API Key 加密金鑰（至少 32 字元的隨機字串，使用 `openssl rand -base64 32` 生成）
AI_ENCRYPTION_SECRET=

# ===== 僅 Production（Vercel）=====
# CRON_SECRET=
